{
  "name": "react-typace",
  "version": "1.1.2",
  "description": "React hook that learns how your users type to debounce searches intelligently",
  "author": "Gleb Safiannikov <tylerdelmas0@gmail.com>",
  "license": "MIT",
  "module": "./dist/index.mjs",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/just1po1nt0/typace.git"
  },
  "scripts": {
    "compile": "tsup",
    "build": "tsup && npm pack",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/jest": "^29.5.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.10",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^19.2.4",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.1.3"
  },
  "keywords": [
    "react",
    "debounce",
    "adaptive",
    "profiling",
    "data analysis",
    "private",
    "privacy"
  ],
  "bugs": {
    "url": "https://github.com/just1po1nt0/typace/discussions/categories/please-report-bugs-here"
  },
  "homepage": "https://github.com/just1po1nt0/typace"
}
